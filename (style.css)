:root { 
    --p1: #00f3ff; 
    --p2: #ff00f7; 
    --ui-aura: rgba(173, 216, 230, 0.4); 
}

body { 
    margin: 0; 
    background: #000 url('https://images.alphacoders.com/906/906100.jpg') no-repeat center center fixed; 
    background-size: cover;
    color: white; 
    font-family: 'Orbitron', sans-serif; 
    height: 100vh; 
    display: flex; 
    align-items: center; 
    justify-content: center; 
    overflow: hidden; 
}

/* --- UI OVERLAY --- */
.overlay {
    position: fixed; top: 0; left: 0; width: 100%; height: 100%;
    background: rgba(0, 0, 0, 0.4); z-index: -1;
}

.screen { 
    display: none; width: 100%; height: 100%; flex-direction: column; 
    align-items: center; justify-content: center; position: absolute; 
}
.active { display: flex; }

/* GLASS MORPHISM CARDS */
.card { 
    background: rgba(0, 0, 0, 0.75); 
    border: 2px solid var(--p1); 
    padding: 30px; 
    border-radius: 20px; 
    text-align: center; 
    width: 280px; 
    backdrop-filter: blur(10px);
    box-shadow: 0 0 20px var(--ui-aura);
}

.theme-title { color: var(--p1); }

input { 
    background: rgba(255,255,255,0.1); border: 1px solid var(--p1); 
    color: white; padding: 12px; border-radius: 8px; width: 85%; 
    margin-bottom: 15px; text-align: center; font-family: 'Orbitron'; 
}

.btn { 
    display: block; width: 100%; padding: 15px; margin: 5px 0; 
    background: rgba(0, 243, 255, 0.1); border: 1px solid var(--p1); 
    color: var(--p1); border-radius: 10px; cursor: pointer; font-weight: bold; 
    text-transform: uppercase;
}
.btn:hover { 
    background: var(--p1); color: #000; box-shadow: 0 0 15px var(--p1); 
}

/* --- COMBAT HUD --- */
.hud { position: absolute; width: 100%; max-width: 400px; padding: 15px; z-index: 10; }
.top { top: 0; transform: rotate(180deg); }
.bottom { bottom: 0; }

.hp-bar { 
    height: 16px; background: rgba(0,0,0,0.8); border-radius: 8px; 
    overflow: hidden; border: 1px solid #fff; margin: 5px 0; 
}
.fill { 
    height: 100%; width: 100%; 
    transition: 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275); 
}

/* Specific Health Bar Colors */
#p1-fill { background: linear-gradient(90deg, #00f3ff, #80f9ff); }
#p2-fill { background: linear-gradient(90deg, #ff00f7, #ff80fb); }

.moves { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; }
.m-btn { 
    background: rgba(0,0,0,0.6); border: 2px solid white; color: white; 
    padding: 20px; border-radius: 15px; font-size: 1.8rem; cursor: pointer;
    backdrop-filter: blur(5px);
}

#status-msg { 
    position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); 
    text-align: center; width: 100%; color: #fff; font-size: 1.5rem; 
    text-shadow: 0 0 10px var(--p1), 0 0 20px #000; font-weight: 900;
}

/* Reload Button Styling */
.reload-btn {
    position: absolute; right: 10px; top: 50%; 
    background: rgba(0,0,0,0.5); border: 1px solid white; 
    color: white; border-radius: 50%; width: 40px; height: 40px; cursor: pointer;
}
